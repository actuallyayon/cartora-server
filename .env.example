# ─────────────────────────────────────────────
# Cartora Server — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed origins for CORS (client URLs)
CLIENT_ORIGINS=http://localhost:3000

# Database (added/used from Step 2)
MONGODB_URI=
# Optional: comma-separated DNS resolvers, only needed if your network's default
# DNS refuses the SRV lookups that mongodb+srv:// requires (e.g. 1.1.1.1,8.8.8.8).
DNS_SERVERS=

# JWT (added/used from Step 3) — use long random strings (>=32 chars)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Demo accounts (seeded via `npm run seed`) shown on the login page
DEMO_CUSTOMER_EMAIL=demo@cartora.app
DEMO_CUSTOMER_PASSWORD=demo1234
DEMO_ADMIN_EMAIL=admin@cartora.app
DEMO_ADMIN_PASSWORD=admin1234

# ImgBB image hosting (used from Step 6)
IMGBB_API_KEY=

# Stripe (used from Step 11)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (optional, used later)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=
